<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>Ivan & Carmen</title>

  <!-- FONT -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap">

  <!-- CSS 🔥 -->
  <link rel="stylesheet" href="/css/style.css?v=3">
</head>

<body>

<main class="passport-container">

  <!-- Decorazioni esterne -->
  <img src="/images/Rosanautica.png" class="decor decor-compass" alt="">
  <img src="/images/Airmail.png" class="decor decor-stamp" alt="">
  <img src="/images/Aereo.png" class="decor decor-plane" alt="">

  <div class="passport-main">

    <!-- HERO SECTION -->
    <section class="hero-section">
      <h1 class="names-title">Ivan & Carmen</h1>
      <p class="wedding-subtitle-large">4 Settembre 2026 · Ore 11:00</p>
      
      <div class="countdown-box-v2">
        <div id="countdown" class="countdown-timer-v2">
          <!-- Caricato via JS -->
          <div class="cd-unit"><span>00</span><small>giorni</small></div>
          <div class="cd-sep">·</div>
          <div class="cd-unit"><span>00</span><small>ore</small></div>
          <div class="cd-sep">·</div>
          <div class="cd-unit"><span>00</span><small>min</small></div>
          <div class="cd-sep">·</div>
          <div class="cd-unit cd-sec"><span>00</span><small>sec</small></div>
        </div>
      </div>
    </section>

    <!-- CONTENT GRID -->
    <div class="content-grid-aligned">
      
      <!-- LA CERIMONIA -->
      <section class="card card-cerimonia">
        <div class="card-header-decor"></div>
        <h2>La Cerimonia</h2>
        
        <div class="card-body">
          <div class="card-img-wrapper">
            <img src="/images/Chiesa.jpg" alt="Chiesa">
          </div>
          
          <div class="card-side-info">
             <p class="time-highlight">Ore 11:00</p>
             <p class="location-name">Chiesa dei SS. Alessandro e Tiburzio</p>
             <p class="address-tag">Via Indipendenza 1, Besozzo</p>
             
             <div class="map-embed">
               <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m13!1d2780.812613146433!2d8.665487776822453!3d45.84501430725597!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47867be49448834d%3A0x69680c85c392434!2sChiesa%20dei%20SS.%20Alessandro%20e%20Tiburzio!5e0!3m2!1sit!2sit!4v1716388484194!5m2!1sit!2sit" width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
             </div>

             <a href="https://maps.app.goo.gl/3f8H3mX8jYm9jYm9" target="_blank" class="map-link-btn">
                Apri in Google Maps
             </a>
          </div>
        </div>
      </section>

      <!-- IL RICEVIMENTO -->
      <section class="card card-ricevimento">
        <h2>Il Ricevimento</h2>
        <div class="card-body">
          <div class="card-img-wrapper">
            <img src="/images/Ristorante.jpg" alt="Ristorante">
          </div>
          <div class="card-content">
            <p class="subtitle-elegant">A seguire i festeggiamenti presso</p>
            <p class="location-name">Ristorante San Carlo</p>
            <p class="address-tag">Via Verbano 4, Arona</p>
            
            <div class="map-embed">
              <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m13!1d2784.774577452601!2d8.563458876817688!3d45.76566061458923!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47867d7a8d5f303f%3A0x8670c7c8f7d4c062!2sRistorante%20San%20Carlo!5e0!3m2!1sit!2sit!4v1716388654118!5m2!1sit!2sit" width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>

            <a href="https://maps.app.goo.gl/3f8H3mX8jYm9jYm9" target="_blank" class="map-link-btn">
              Apri in Google Maps
            </a>
            
            <div class="parking-note-elegant">
              <i class="icon-info"></i>
              <p>Consigliamo di parcheggiare nello sterrato accanto al parcheggio San Carlo.</p>
            </div>
          </div>
        </div>
      </section>
    </div> <!-- end content-grid-aligned -->

    <!-- RSVP FORM (FUORI DALLA GRID) -->
    <section class="card card-rsvp-full">
      <div class="rsvp-header">
        <h3>Conferma la tua presenza</h3>
        <p class="rsvp-deadline">È gradita gentile conferma entro il 18 luglio</p>
      </div>
      
      <form class="professional-form" action="/rsvp" method="post">
        <div class="form-grid">
          <div class="form-field full">
            <label for="nome">Nome e Cognome</label>
            <input type="text" id="nome" name="nome" placeholder="Esempio: Mario Rossi" required>
          </div>
          
          <div class="form-field full">
            <label>Sarai presente?</label>
            <div class="radio-options">
              <label class="radio-card">
                <input type="radio" name="presenza" value="si" checked>
                <span class="radio-box">Sì, mi unirò ai festeggiamenti</span>
              </label>
              <label class="radio-card">
                <input type="radio" name="presenza" value="no">
                <span class="radio-box">No, non potrò esserci</span>
              </label>
            </div>
          </div>

          <div class="form-field">
            <label for="p_num">Numero partecipanti</label>
            <input type="number" id="p_num" name="partecipanti_num" min="1" placeholder="Totale persone">
          </div>

          <div class="form-field">
            <label for="p_nomi">Nome e cognome partecipanti</label>
            <input type="text" id="p_nomi" name="partecipanti_nomi" placeholder="Esempio: Anna, Marco...">
          </div>

          <div class="form-field full">
            <label for="allergie">Allergie, intolleranze o regimi alimentari</label>
            <textarea id="allergie" name="allergie" placeholder="Specifica il nominativo e l'esigenza (es. Mario: celiaco)"></textarea>
          </div>

          <div class="form-field">
            <label for="b_eta">Età dei vostri bambini</label>
            <input type="text" id="b_eta" name="bambini_eta" placeholder="Es: 4 e 7 anni">
          </div>

          <div class="form-field full">
            <label for="mess">Un messaggio per gli sposi</label>
            <textarea id="mess" name="messaggio" placeholder="Scrivici un pensiero..."></textarea>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-send-professional">
            Invia Conferma
            <span class="btn-icon">✈</span>
          </button>
        </div>
      </form>
    </section>

    <!-- Decorazione fiori in fondo -->
    <div class="footer-flowers"></div>

  </div> <!-- end passport-main -->

</main>

<script>
const targetDate = new Date("September 4, 2026 11:00:00").getTime();

function updateCountdown() {
  const now = new Date().getTime();
  const diff = targetDate - now;

  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
  const minutes = Math.floor((diff / (1000 * 60)) % 60);
  const seconds = Math.floor((diff / 1000) % 60);

  document.getElementById("countdown").innerHTML = `
    <div class="cd-unit"><span>${days}</span><small>giorni</small></div>
    <div class="cd-sep">·</div>
    <div class="cd-unit"><span>${hours}</span><small>ore</small></div>
    <div class="cd-sep">·</div>
    <div class="cd-unit"><span>${minutes}</span><small>min</small></div>
    <div class="cd-sep">·</div>
    <div class="cd-unit cd-sec"><span>${seconds}</span><small>sec</small></div>
  `;
}

updateCountdown();
setInterval(updateCountdown, 1000); // Aggiorna ogni secondo
</script>

</body>
</html>