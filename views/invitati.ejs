<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= couple %> — Invitati</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Cormorant+Garamond:wght@300;400;500&display=swap">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="brand"><span class="names"><%= couple %></span></div>
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/invitati" class="active">Invitati</a>
      <form class="logout" action="/logout" method="post">
        <button type="submit">Logout</button>
      </form>
    </nav>
  </header>
  <main class="content">
    <section class="list-section">
      <h1 class="title">Invitati</h1>
      <ul class="guest-list">
        <% if (invitati && invitati.length) { %>
          <% invitati.forEach(function(item){ %>
            <li class="guest">
              <span class="guest-name"><%= item.nome %></span>
              <% if (item.note) { %><span class="guest-note"><%= item.note %></span><% } %>
            </li>
          <% }) %>
        <% } else { %>
          <li class="guest empty">Nessun invitato presente al momento</li>
        <% } %>
      </ul>
    </section>
  </main>
  <footer class="site-footer">
    <span>Celebratione di <%= couple %></span>
  </footer>
</body>
</html>
