<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Lista Invitati — <%= couple %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap">
  <link rel="stylesheet" href="/css/style.css?v=3">
  <style>
    .guests-container {
      max-width: 1200px;
      margin: 40px auto;
      padding: 20px;
      background: rgba(255, 255, 255, 0.9);
      border-radius: 15px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .back-btn {
      display: inline-block;
      margin-bottom: 20px;
      padding: 10px 20px;
      background: #1a3c5e;
      color: white;
      text-decoration: none;
      border-radius: 50px;
      font-family: "Cormorant Garamond", serif;
      font-weight: 700;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
      font-family: "Cormorant Garamond", serif;
    }
    th, td {
      padding: 15px;
      text-align: left;
      border-bottom: 1px solid rgba(26, 60, 94, 0.1);
      font-family: sans-serif;
    font-weight: 600;
    }
    th {
      background: #1a3c5e;
      color: white;
      font-family: "Cormorant Garamond", serif;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    tr:hover {
      background: rgba(26, 60, 94, 0.05);
    }
    .status-presenza {
      padding: 5px 10px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 700;
    }
    .status-si { background: #d4edda; color: #155724; }
    .status-no { background: #f8d7da; color: #721c24; }
    /* MOBILE VERSION */
@media (max-width: 768px) {

  table, thead, tbody, th, td, tr {
    display: block;
    width: 100%;
  }

  thead {
    display: none;
  }

  tr {
    margin-bottom: 20px;
    background: white;
    border-radius: 12px;
    padding: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }

  td {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border: none;
    border-bottom: 1px solid #eee;
  }

  td:last-child {
    border-bottom: none;
  }

  td::before {
    content: attr(data-label);
    font-weight: bold;
    color: #1a3c5e;
  }

  .guests-container {
    padding: 10px;
  }

  h1 {
    font-size: 2rem !important;
  }
}
  </style>
</head>
<body>
  <div class="guests-container">
    <a href="/" class="back-btn">← Torna al sito</a>
    <h1 style="font-family: 'Great Vibes', cursive; font-size: 3rem; color: #1a3c5e; text-align: center;">Lista Invitati</h1>
    <div style="margin-bottom:20px; font-family: 'Great Vibes', cursive; font-size: 1.2rem;">
  <strong>Totale risposte:</strong> <%= rsvps.length %><br>

  <strong>Presenti:</strong> 
  <%= rsvps.filter(r => r.presenza === 'si').length %><br>

  <strong>Non presenti:</strong> 
  <%= rsvps.filter(r => r.presenza === 'no').length %>
</div>
    <table>
      <thead>
        <tr>
          <th>Nome</th>
          <th>Presenza</th>
          <th>N° Persone</th>
          <th>Nomi Partecipanti</th>
          <th>Allergie</th>
          <th>Età Bambini</th>
          <th>Messaggio</th>
        </tr>
      </thead>
      <tbody>
        <% if (rsvps && rsvps.length > 0) { %>
          <% rsvps.reverse().forEach(function(rsvp) { %>
            <tr>
              <td data-label="Nome"><strong><%= rsvp.nome %></strong></td>
              <td data-label="Presenza">
  <span class="status-presenza <%= rsvp.presenza === 'si' ? 'status-si' : 'status-no' %>">
    <%= rsvp.presenza === 'si' ? 'SÌ' : 'NO' %>
  </span>
</td>

<td data-label="N° Persone"><%= rsvp.partecipanti_num || '-' %></td>

<td data-label="Partecipanti"><%= rsvp.partecipanti_nomi || '-' %></td>

<td data-label="Allergie"><%= rsvp.allergie || '-' %></td>

<td data-label="Bambini"><%= rsvp.bambini_eta || '-' %></td>

<td data-label="Messaggio"><small><%= rsvp.messaggio || '-' %></small></td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="7" style="text-align: center; padding: 40px;">Ancora nessuna risposta ricevuta.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>